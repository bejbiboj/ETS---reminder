<Window x:Class="ETS_reminder.BulkEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Bulk Entry"
        Width="480" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D35400"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource DisabledButtonBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Bulk Entry"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#E67E22"
                   Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1"
                   Text="Fill the same entry for a range of dates."
                   FontSize="13"
                   Foreground="{DynamicResource SubTextColor}"
                   Margin="0,0,0,15"/>

        <!-- Date Range -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackground}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="From:"
                           Foreground="{DynamicResource TextColor}"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                <DatePicker Grid.Row="0" Grid.Column="1"
                            x:Name="StartDatePicker"
                            FontSize="13"
                            Margin="0,0,16,0"
                            DisplayDateEnd="{x:Static sys:DateTime.Today}"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="To:"
                           Foreground="{DynamicResource TextColor}"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                <DatePicker Grid.Row="0" Grid.Column="3"
                            x:Name="EndDatePicker"
                            FontSize="13"
                            DisplayDateEnd="{x:Static sys:DateTime.Today}"/>

                <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                          x:Name="WeekdaysOnlyCheckBox"
                          Content="Weekdays only (skip Sat/Sun)"
                          IsChecked="True"
                          Foreground="{DynamicResource TextColor}"
                          FontSize="13"
                          VerticalContentAlignment="Center"
                          Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- Entry Type -->
        <Border Grid.Row="3"
                Background="{DynamicResource PanelBackground}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Entry Type"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#D35400"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="EntryTypeComboBox"
                          FontSize="13"
                          Padding="6,4"
                          SelectionChanged="EntryTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="HOLIDAY" IsSelected="True"/>
                    <ComboBoxItem Content="SICK LEAVE"/>
                    <ComboBoxItem Content="VACATION"/>
                    <ComboBoxItem Content="WFH - Working from home"/>
                    <ComboBoxItem Content="Custom..."/>
                </ComboBox>
                <TextBox x:Name="CustomEntryTextBox"
                         FontSize="13"
                         Padding="6,4"
                         Margin="0,8,0,0"
                         Visibility="Collapsed"
                         SpellCheck.IsEnabled="True"
                         Background="{DynamicResource TextBoxBackground}"
                         Foreground="{DynamicResource TextBoxForeground}"
                         BorderBrush="{DynamicResource TextBoxBorder}"/>
            </StackPanel>
        </Border>

        <!-- Skip existing -->
        <CheckBox Grid.Row="4"
                  x:Name="SkipExistingCheckBox"
                  Content="Skip dates that already have a report"
                  IsChecked="True"
                  Foreground="{DynamicResource TextColor}"
                  FontSize="13"
                  VerticalContentAlignment="Center"
                  Margin="0,0,0,12"/>

        <!-- Summary -->
        <TextBlock Grid.Row="5"
                   x:Name="SummaryText"
                   Text=""
                   FontSize="12"
                   Foreground="{DynamicResource SubTextColor}"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save Entries"
                    x:Name="SaveButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    FontSize="14"
                    Padding="20,8"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
