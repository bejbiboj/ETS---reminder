<Window x:Class="ETS_reminder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETS Reminder Settings"
        Width="480" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D35400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#E67E22"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <CheckBox x:Name="DarkModeCheckBox"
                      Content="Dark mode"/>

            <CheckBox x:Name="AutoSaveDraftCheckBox"
                      Content="Auto-save draft while typing"/>

            <CheckBox x:Name="ShowLogViewerOnStartupCheckBox"
                      Content="Show Log Viewer on startup"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <TextBlock Text="Auto-save interval:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,10,0"/>
                <TextBox x:Name="AutoSaveIntervalTextBox"
                         Width="60"
                         FontSize="14"
                         Padding="5,3"
                         Background="{DynamicResource TextBoxBackground}"
                         Foreground="{DynamicResource TextBoxForeground}"
                         BorderBrush="{DynamicResource TextBoxBorder}"/>
                <TextBlock Text="seconds"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource TextColor}"
                           Margin="10,0,0,0"/>
            </StackPanel>

            <StackPanel Margin="0,15,0,0">
                <TextBlock Text="Time zone:"
                           FontSize="14"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="TimeZoneComboBox"
                          FontSize="13"
                          Padding="5,3"
                          BorderBrush="{DynamicResource TextBoxBorder}"
                          MaxDropDownHeight="250"
                          IsEditable="True"
                          IsTextSearchEnabled="True"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <TextBlock Text="Reminder start time:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource TextColor}"
                           Margin="0,0,10,0"/>
                <ComboBox x:Name="ReminderHourComboBox"
                          Width="55"
                          FontSize="14"
                          Padding="5,3"
                          BorderBrush="{DynamicResource TextBoxBorder}"/>
                <TextBlock Text=":" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextColor}" Margin="4,0"/>
                <ComboBox x:Name="ReminderMinuteComboBox"
                          Width="55"
                          FontSize="14"
                          Padding="5,3"
                          BorderBrush="{DynamicResource TextBoxBorder}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    FontSize="14"
                    Padding="20,8"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
