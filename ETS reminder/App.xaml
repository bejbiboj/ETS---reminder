<Application x:Class="ETS_reminder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Theme Brushes (defaults = light mode, swapped at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="WindowBackground" Color="#FFF8F0"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FDEBD0"/>
        <SolidColorBrush x:Key="SidePanelBackground" Color="#FDF2E9"/>
        <SolidColorBrush x:Key="MenuBackground" Color="#FDEBD0"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0C5A0"/>
        <SolidColorBrush x:Key="TextColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SubTextColor" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="ContentText" Color="#2C3E50"/>
        <SolidColorBrush x:Key="ListBackground" Color="White"/>
        <SolidColorBrush x:Key="ListItemBorder" Color="#F0E0C8"/>
        <SolidColorBrush x:Key="ListItemHover" Color="#FDEBD0"/>
        <SolidColorBrush x:Key="TextBoxBackground" Color="White"/>
        <SolidColorBrush x:Key="TextBoxForeground" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextBoxBorder" Color="#E0C5A0"/>
        <SolidColorBrush x:Key="DisabledButtonBackground" Color="#CCCCCC"/>

        <!-- Dropdown items: always black text on the default white popup -->
        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Application.Resources>
</Application>
