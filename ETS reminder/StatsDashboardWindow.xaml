<Window x:Class="ETS_reminder.StatsDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stats Dashboard"
        Width="500" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="25">

            <!-- Profile Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border x:Name="AvatarBorder"
                        Width="60" Height="60"
                        CornerRadius="30"
                        Background="#E67E22">
                    <TextBlock x:Name="AvatarInitials"
                               Text="?"
                               FontSize="24" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ProfileName"
                               Text="User"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextColor}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ProfileLevel"
                                   Text="Level 1"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E67E22"/>
                        <TextBlock x:Name="ProfileTitle"
                                   Text=" - Newcomer"
                                   FontSize="13"
                                   Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                    <TextBlock x:Name="ProfileRole"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource SubTextColor}"/>
                </StackPanel>
            </StackPanel>

            <!-- Level Progress Bar -->
            <TextBlock x:Name="LevelProgressLabel"
                       Text="Progress to next level"
                       FontSize="12" Foreground="{DynamicResource SubTextColor}"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource BorderColor}" CornerRadius="5" Height="10" Margin="0,0,0,20">
                <Border x:Name="LevelProgressBar"
                        Background="#E67E22"
                        CornerRadius="5"
                        HorizontalAlignment="Left"
                        Width="0"/>
            </Border>

            <!-- Stats Grid -->
            <UniformGrid Columns="2" Margin="0,0,0,10">
                <!-- Current Streak -->
                <Border x:Name="StreakBorder" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,5,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="StreakFireEmoji" Text="&#x1F525;" FontSize="22" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="FireScale" ScaleX="1" ScaleY="1"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="CurrentStreakText"
                                   Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#E67E22" HorizontalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="StreakNumberScale" ScaleX="1" ScaleY="1"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="Current Streak"
                                   FontSize="12" Foreground="{DynamicResource SubTextColor}"
                                   HorizontalAlignment="Center"/>
                        <!-- Milestone banner -->
                        <Border x:Name="MilestoneBanner" CornerRadius="4" Padding="8,3" Margin="0,6,0,0"
                                Background="#E67E22" Opacity="0" HorizontalAlignment="Center">
                            <TextBlock x:Name="MilestoneText" Text="" FontSize="11" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Longest Streak -->
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="5,0,0,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F3C6;" FontSize="22" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LongestStreakText"
                                   Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#E67E22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Longest Streak"
                                   FontSize="12" Foreground="{DynamicResource SubTextColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Total Reports -->
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,5,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4CB;" FontSize="22" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalReportsText"
                                   Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#E67E22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Reports"
                                   FontSize="12" Foreground="{DynamicResource SubTextColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Coins -->
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="5,0,0,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4B0;" FontSize="22" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalCoinsText"
                                   Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#E67E22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Coins"
                                   FontSize="12" Foreground="{DynamicResource SubTextColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- This Week -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="This Week"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock x:Name="WeekDateRange"
                                   Text=""
                                   FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Day indicators (Mon-Fri) -->
                    <UniformGrid Columns="5" Margin="0,0,0,10">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="DayMon" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BorderColor}">
                                <TextBlock Text="&#x2713;" FontSize="16" FontFamily="Segoe UI Emoji" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DayMonCheck"/>
                            </Border>
                            <TextBlock Text="Mon" FontSize="10" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="DayTue" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BorderColor}">
                                <TextBlock Text="&#x2713;" FontSize="16" FontFamily="Segoe UI Emoji" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DayTueCheck"/>
                            </Border>
                            <TextBlock Text="Tue" FontSize="10" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="DayWed" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BorderColor}">
                                <TextBlock Text="&#x2713;" FontSize="16" FontFamily="Segoe UI Emoji" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DayWedCheck"/>
                            </Border>
                            <TextBlock Text="Wed" FontSize="10" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="DayThu" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BorderColor}">
                                <TextBlock Text="&#x2713;" FontSize="16" FontFamily="Segoe UI Emoji" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DayThuCheck"/>
                            </Border>
                            <TextBlock Text="Thu" FontSize="10" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="DayFri" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BorderColor}">
                                <TextBlock Text="&#x2713;" FontSize="16" FontFamily="Segoe UI Emoji" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DayFriCheck"/>
                            </Border>
                            <TextBlock Text="Fri" FontSize="10" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock x:Name="WeekSummaryText"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource SubTextColor}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Completion Rate -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right"
                               x:Name="CompletionRateText"
                               Text="0%"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#E67E22"
                               VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Completion Rate"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="Reports filed vs weekdays"
                                   FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Today's Earnings -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right"
                               x:Name="TodayCoinsText"
                               Text="+0"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#2ECC71"
                               VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Today's Earnings"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock x:Name="TodayCoinsDetail"
                                   Text="Fill your report to earn coins!"
                                   FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Streak Bonus Info -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Streak Bonuses"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="3+ days: +1 bonus coin per report"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock Text="5+ days: +2 bonus coins per report"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock Text="10+ days: +3 bonus coins per report"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock Text="20+ days: +5 bonus coins per report"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                </StackPanel>
            </Border>

            <!-- Achievements -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Achievements"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock x:Name="AchievementCountText"
                                   Text=" (0/0)"
                                   FontSize="14"
                                   Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                    <ItemsControl x:Name="AchievementsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="8,6"
                                        CornerRadius="6"
                                        Background="{DynamicResource WindowBackground}"
                                        Opacity="{Binding Opacity}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Icon}"
                                                   FontSize="20" FontFamily="Segoe UI Emoji"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{Binding NameColor}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubTextColor}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Rules Info -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Coin Rules"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="&#x2022; Same-day reports earn coins + streak bonus"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}" TextWrapping="Wrap"/>
                    <TextBlock Text="&#x2022; Backdated reports: saved for records, 0 coins"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}" TextWrapping="Wrap"/>
                    <TextBlock Text="&#x2022; Holiday / Sick / Vacation: 0 coins, streak preserved"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}" TextWrapping="Wrap"/>
                    <TextBlock Text="&#x2022; Future dates are blocked"
                               FontSize="12" Foreground="{DynamicResource SubTextColor}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
