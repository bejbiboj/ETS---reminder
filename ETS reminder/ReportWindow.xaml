<Window x:Class="ETS_reminder.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETS Daily Report"
        Width="600" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackground}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D35400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton" x:Key="ToolbarToggle">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelBackground}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E67E22"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="ETS Daily Report"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#E67E22"
                   Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1"
                   x:Name="DateLabel"
                   FontSize="13" Foreground="{DynamicResource SubTextColor}"
                   Margin="0,0,0,10"/>

        <!-- Find Bar (hidden by default) -->
        <Border Grid.Row="2"
                x:Name="FindBar"
                Background="{DynamicResource PanelBackground}"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="X"
                        FontSize="12"
                        Padding="8,4"
                        Click="CloseFindBar_Click"
                        ToolTip="Close (Escape)"
                        Margin="5,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content=">"
                        FontSize="12"
                        FontWeight="Bold"
                        Padding="8,4"
                        Click="FindNext_Click"
                        ToolTip="Find Next (Enter)"/>
                <Button DockPanel.Dock="Right"
                        Content="&lt;"
                        FontSize="12"
                        FontWeight="Bold"
                        Padding="8,4"
                        Click="FindPrevious_Click"
                        ToolTip="Find Previous (Shift+Enter)"
                        Margin="0,0,5,0"/>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="FindResultsLabel"
                           Text=""
                           FontSize="11"
                           Foreground="{DynamicResource SubTextColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="Find:"
                           FontSize="13"
                           Foreground="{DynamicResource TextColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="FindTextBox"
                         FontSize="13"
                         Padding="5,3"
                         Background="{DynamicResource TextBoxBackground}"
                         Foreground="{DynamicResource TextBoxForeground}"
                         BorderBrush="{DynamicResource TextBoxBorder}"
                         TextChanged="FindTextBox_TextChanged"
                         PreviewKeyDown="FindTextBox_PreviewKeyDown"/>
            </DockPanel>
        </Border>

        <!-- Formatting Toolbar -->
        <Border Grid.Row="3"
                Background="{DynamicResource PanelBackground}"
                CornerRadius="4"
                Padding="4,3"
                Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <ToggleButton x:Name="BoldButton" Content="B" FontWeight="Bold"
                              Style="{StaticResource ToolbarToggle}" ToolTip="Bold (Ctrl+B)"
                              Click="Bold_Click"/>
                <ToggleButton x:Name="ItalicButton" Content="I" FontStyle="Italic"
                              Style="{StaticResource ToolbarToggle}" ToolTip="Italic (Ctrl+I)"
                              Click="Italic_Click"/>
                <ToggleButton x:Name="UnderlineButton" Content="U"
                              Style="{StaticResource ToolbarToggle}" ToolTip="Underline (Ctrl+U)"
                              Click="Underline_Click">
                    <ToggleButton.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="U" TextDecorations="Underline"/>
                        </DataTemplate>
                    </ToggleButton.ContentTemplate>
                </ToggleButton>

                <Border Width="1" Background="{DynamicResource BorderColor}" Margin="6,4"/>

                <Button Content="&#x2022;" FontSize="16" Style="{StaticResource ToolbarButton}"
                        ToolTip="Bullet List" Click="BulletList_Click"/>

                <Border Width="1" Background="{DynamicResource BorderColor}" Margin="6,4"/>

                <ComboBox x:Name="FontSizeComboBox" Width="55" FontSize="12"
                          Padding="3,2" VerticalContentAlignment="Center"
                          BorderBrush="{DynamicResource TextBoxBorder}"
                          SelectionChanged="FontSize_SelectionChanged"
                          ToolTip="Font Size"/>
            </StackPanel>
        </Border>

        <RichTextBox Grid.Row="4"
                 x:Name="ReportRichTextBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 SpellCheck.IsEnabled="True"
                 IsInactiveSelectionHighlightEnabled="True"
                 SelectionBrush="#E67E22"
                 FontSize="14"
                 FontFamily="Segoe UI"
                 Padding="10"
                 Background="{DynamicResource TextBoxBackground}"
                 Foreground="{DynamicResource TextBoxForeground}"
                 BorderBrush="{DynamicResource TextBoxBorder}"
                 BorderThickness="1"
                 Margin="0,0,0,5"
                 TextChanged="ReportRichTextBox_TextChanged"
                 SelectionChanged="ReportRichTextBox_SelectionChanged">
            <RichTextBox.Document>
                <FlowDocument/>
            </RichTextBox.Document>
        </RichTextBox>

        <!-- Status bar with word/character count -->
        <TextBlock Grid.Row="5"
                   x:Name="StatusBar"
                   Text="Words: 0 | Characters: 0"
                   FontSize="11"
                   Foreground="{DynamicResource SubTextColor}"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="View Logs"
                    FontSize="14"
                    Padding="20,8"
                    Click="ViewLogsButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Save Report"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    FontSize="14"
                    Padding="20,8"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
